{
  "name": "mosh",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "npm run build:web",
    "build:web": "tsc && vite build",
    "test": "vitest run",
    "preview": "vite preview",
    "moss:sync": "git submodule update --init --remote --recursive moss",
    "moss:bundle": "node ./scripts/build-moss-runtime.mjs",
    "desktop:prepare": "npm run moss:sync && npm run moss:bundle",
    "tauri": "tauri",
    "tauri:dev": "npm run desktop:prepare && tauri dev",
    "tauri:build": "npm run desktop:prepare && tauri build"
  },
