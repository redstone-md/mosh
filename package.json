    "@radix-ui/react-tabs": "1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.90.3",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-deep-link": "^2.4.7",
    "@tauri-apps/plugin-dialog": "^2.6.0",
