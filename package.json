{
  "name": "mosh",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "tsc && vite build",
    "build:app": "npm run moss:prepare && npm run tauri build",
    "preview": "vite preview",
    "test": "npm run typecheck && vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
    "format": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "tauri": "tauri",
    "moss:update": "node --experimental-strip-types scripts/moss-update.mjs",
    "moss:prepare": "node scripts/moss-prepare.mjs"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.41.1",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "jsdom": "^29.1.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.5"
  }
}
