{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Mosh",
  "version": "0.6.0",
  "identifier": "app.mosh.desktop",
  "build": {
    "beforeDevCommand": "npm run moss:prepare && npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run moss:prepare && npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Mosh",
        "width": 1180,
        "height": 760,
        "minWidth": 520,
        "minHeight": 520
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["moss-runtime/*"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

