{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MOSH",
  "version": "0.1.0",
  "identifier": "md.redstone.mosh",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build:web",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "MOSH",
        "width": 1440,
        "height": 960,
        "minWidth": 1100,
        "minHeight": 760,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["mosh", "mosh-identity"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": ["resources/moss/*"],
    "icon": ["icons/32x32.png", "icons/128x128.png", "icons/128x128@2x.png", "icons/icon.ico", "icons/icon.icns"]
  }
}
